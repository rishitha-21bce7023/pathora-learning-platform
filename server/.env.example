PORT=5005
MONGODB_URI=mongodb://127.0.0.1:27017/pathora
JWT_SECRET=pathora_super_secret_key_2026_learning_platform_very_long_random_value
CLIENT_URL=http://localhost:5173

# Required for PDF notes uploads.
# Notes are uploaded as Cloudinary raw files and MongoDB stores the secure URL.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_NOTES_FOLDER=pathora/notes

# Optional: used only by `npm run seed:admin`.
SEED_ADMIN_NAME=Pathora Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_this_long_admin_password

# Python code execution runs fully in the browser with Pyodide.
# No Judge0 URL, host, or API key is required.
